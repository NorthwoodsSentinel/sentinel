# Sentinel Poller Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Shared ---
SENTINEL_URL="https://your-sentinel.workers.dev"
SENTINEL_CLIENT="home"

# --- Gateway DNS Poller ---
CF_ACCOUNT="YOUR_CLOUDFLARE_ACCOUNT_ID"
ZT_TOKEN_FILE="$HOME/.secrets/cf_zt_token"

# --- UniFi Poller ---
UNIFI_HOST="https://YOUR_UDM_IP"
UNIFI_SITE="YOUR_UNIFI_SITE_UUID"
UNIFI_KEY_FILE="$HOME/.secrets/unifi_api_key"
